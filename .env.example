# Required
OPENAI_API_KEY=sk-...
SARVAM_API_KEY=...

# Optional - for baseline measurement only
DEEPGRAM_API_KEY=...

# Whisper model size: tiny, base, small, medium (default: small)
WHISPER_MODEL=small

# Sarvam TTS voice + model
# bulbul:v3 supports: rohan, anushka, vidya, arya, karun, hitesh
# bulbul:v2 supports: anushka, abhilash, manisha, vidya, arya, karun, hitesh
SARVAM_SPEAKER=rohan
SARVAM_MODEL=bulbul:v3
